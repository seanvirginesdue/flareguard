# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep the example template, ignore everything else
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# firebase credentials and service account keys
*.json
!package.json
!package-lock.json
!tsconfig.json
!vercel.json

# YOLO model weights
*.pt
*.onnx
*.weights

# video files
*.mp4
*.mov
*.avi

# Python
__pycache__/
*.pyc
*.pyo
.Python
dist/
*.egg-info/

# Docker volumes / local overrides
docker-compose.override.yml
