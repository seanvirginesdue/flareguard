# ============================================================
# FlareGuard — Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to git.
# ============================================================

# ------------------------------------------------------------
# Firebase Admin SDK (server-side — Next.js API routes + Flask)
# Get from: Firebase Console → Project Settings → Service Accounts
# → Generate new private key → download JSON
# Paste the ENTIRE JSON content as a single line (no newlines)
# ------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=        # Keep \n as literal \n (do not expand newlines)

# For the Flask backend: paste the entire service account JSON as one line
FIREBASE_SERVICE_ACCOUNT_JSON=

# ------------------------------------------------------------
# Supabase (server-side — Flask backend)
# Get from: Supabase Dashboard → Project Settings → API
# Use the SERVICE ROLE key (not the anon key) for the backend
# ------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------
# Flask backend URL (used by Next.js to proxy video streams)
# Local dev:  http://localhost:5000
# Production: https://your-server-ip-or-domain
# ------------------------------------------------------------
FLASK_URL=http://localhost:5000

# ------------------------------------------------------------
# Firebase Web SDK (client-side — browser)
# Get from: Firebase Console → Project Settings → Your apps → Web app
# These are NEXT_PUBLIC so they are bundled into the browser build.
# The web API key is safe to be public; security is enforced by
# Firebase Auth rules and Firestore rules, not by the key itself.
# ------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ------------------------------------------------------------
# Supabase (client-side — optional, only if used in browser)
# Use the ANON key (not the service role key) for client-side
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
